# Virtual Dreams Bot Environment Configuration
# Copy this to .env and configure as needed

# Required: Telegram Bot Token
TOKEN=your_telegram_bot_token_here

# Optional: Redis Configuration for Distributed Caching
# If not set, will use local file-based caching only
REDIS_URL=redis://localhost:6379/0

# Optional: Cache Configuration
CACHE_DIR=cache
CACHE_SIZE_MB=500
CACHE_TTL_DAYS=7

# Optional: Heroku Configuration
PORT=8443